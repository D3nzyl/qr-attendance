# Base URL of the app
BETTER_AUTH_URL=http://localhost:3000
# Secret used to sign auth tokens — generate with `openssl rand -hex 16`
BETTER_AUTH_SECRET=

# Base URL of the AS2 platform API gateway (as2-platform-sdk). Exposed to the
# browser, so it must be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_AS2_BASE_URL=https://api.allocatespace.co

# MongoDB connection string used by Prisma.
# MongoDB must run as a replica set (Prisma requires it). Examples:
#   Local replica set:  mongodb://localhost:27017/qr-attendance?replicaSet=rs0
#   MongoDB Atlas:       mongodb+srv://<user>:<password>@<cluster>.mongodb.net/qr-attendance?retryWrites=true&w=majority
DATABASE_URL=
