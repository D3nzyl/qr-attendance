{
  // This project uses Prisma 6 (Prisma 7 has no MongoDB support), but the Prisma
  // VS Code extension defaults to Prisma 7 rules and wrongly flags `url` in the
  // datasource block. Pin the language server to Prisma 6 so validation matches
  // the installed CLI.
  "prisma.pinToPrisma6": true,
  "prisma.hidePrisma6Prompts": true
}
